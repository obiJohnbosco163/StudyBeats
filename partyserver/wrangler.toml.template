name = "{{TAROBASE_APP_NAME}}"
main = 'src/index.ts'
account_id = "{{CLOUDFLARE_ACCOUNT_ID}}"
workers_dev = false
compatibility_date = "2025-08-15"
compatibility_flags = [
  "nodejs_compat",
  "nodejs_compat_populate_process_env"
]
tail_consumers = [{ service = "poof-log-tail" }]

[vars]
TAROBASE_APP_ID = "{{TAROBASE_APP_ID}}"
ENV = "{{ENV}}"
JWT_ISSUER = "https://cognito-idp.us-east-1.amazonaws.com/us-east-1_Y2DTcFzKs"
NODE_ENV = "{{NODE_ENV}}"
CORS_DEV_DOMAINS = "{{CORS_DEV_DOMAINS}}"
CORS_PROD_DOMAINS = "{{CORS_PROD_DOMAINS}}"
CORS_APP_ID = "{{CORS_APP_ID}}"
TAROBASE_CHAIN = "{{TAROBASE_CHAIN}}"
POOF_MASTER_APP_ID = "{{POOF_MASTER_APP_ID}}"
POOF_ADMIN_ADDRESSES = "{{POOF_ADMIN_ADDRESSES}}"
# OKX onchainos wallet sandbox toggle. Generated by Poof from poof-agents.json
# at deploy time: if any agent has `"wallet": true`, this block holds
# POOF_WALLET_ENABLED = "true", which the runtime in poof-flue-runtime.ts
# reads to register the `onchainos` bash shim + inject WALLET_SKILL_INSTRUCTIONS
# into the agent system prompt. No opt-in → block stays empty → no wallet
# surface. Has nothing to do with Poof's built-in Solana wallet auth.
# --- START POOF WALLET ---
# --- END POOF WALLET ---
# --- START CONSTANTS ---
# --- END CONSTANTS ---

[limits]
cpu_ms = 300_000

# Queue bindings (including the QueueJobTracker durable object and its
# migration) are generated by Poof from queues.json during deployment.
# Older user projects predate QueueJobTracker, so the binding is only
# emitted when the project actually has queues configured.
# --- START POOF QUEUES ---
# --- END POOF QUEUES ---

# Flue agent Durable Object bindings + migrations are generated by Poof
# from poof-agents.json during deployment. The platform owns this zone — never
# add [[durable_objects.bindings]] or [[migrations]] outside it, the
# deploy validator rejects them. Agent class files live at
# partyserver/.flue/agents/<name>.ts and must be registered with
# definePoofAgent in partyserver/src/index.ts.
# --- START POOF AGENTS ---
# --- END POOF AGENTS ---

# Workers AI is NOT bound here. User code calls Workers AI via the
# `aiRun()` helper in `src/lib/poof-ai.ts`, which does a plain fetch to
# poof-ai.internal. Cloudflare's dispatch runtime routes that fetch
# through poof-ai-outbound, which attaches the dispatcher-enforced script
# name and forwards to the AI proxy. Attribution is handled by the
# platform — nothing on this worker holds an AI credential or identity.
